{
	"description": "Constellation code intelligence hooks inject code_intel MCP awareness into sessions, subagents, and tool selection",
	"hooks": {
		"SessionStart": [
			{
				"matcher": "^(startup|resume|clear)$",
				"hooks": [
					{
						"type": "command",
						"command": "node -e \"require(require('path').join(process.env.CLAUDE_PLUGIN_ROOT,'hooks','inject.js'))('SessionStart')\"",
						"statusMessage": "Loading Constellation context..."
					}
				]
			}
		],
		"SubagentStart": [
			{
				"matcher": ".*",
				"hooks": [
					{
						"type": "command",
						"command": "node -e \"require(require('path').join(process.env.CLAUDE_PLUGIN_ROOT,'hooks','inject.js'))('SubagentStart')\"",
						"statusMessage": "Injecting Constellation context into subagent..."
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "^(Grep|Glob|Bash)$",
				"hooks": [
					{
						"type": "command",
						"command": "node -e \"require(require('path').join(process.env.CLAUDE_PLUGIN_ROOT,'hooks','inject.js'))('PreToolUse')\""
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": ".*",
				"hooks": [
					{
						"type": "command",
						"command": "node -e \"require(require('path').join(process.env.CLAUDE_PLUGIN_ROOT,'hooks','inject.js'))('PreCompact')\"",
						"statusMessage": "Preserving Constellation context..."
					}
				]
			}
		]
	}
}
