{
	"description": "Constellation code intelligence hooks inject code_intel MCP awareness into sessions, subagents, and tool selection",
	"hooks": {
		"SessionStart": [
			{
				"matcher": ".*",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/inject.js\" SessionStart",
						"statusMessage": "Loading Constellation context..."
					}
				]
			}
		],
		"SubagentStart": [
			{
				"matcher": ".*",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/inject.js\" SubagentStart"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Grep|Glob",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/inject.js\" PreToolUse"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/bash.js\""
					}
				]
			}
		]
	}
}
